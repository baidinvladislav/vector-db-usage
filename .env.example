# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=knowledge_base

# Embeddings (FastEmbed model id)
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Chunking
CHUNK_SIZE=1200
CHUNK_OVERLAP=150

# Paths
DOCS_DIR=files

# Ingestion
BATCH_SIZE=64
RECREATE_COLLECTION=false
# Leave empty to index all documents; set e.g. 5 for quick tests
DOCS_LIMIT=
RESULT_LIMIT=5

# Reranker (cross-encoder, always used at query time)
RERANKER_MODEL=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1
RERANK_FETCH_K=50
HYBRID_SEARCH_ENABLED=true
