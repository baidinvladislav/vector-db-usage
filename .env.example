# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=knowledge_base

# Embeddings (FastEmbed model id)
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Chunking
CHUNK_SIZE=800
CHUNK_OVERLAP=120

# Paths
DOCS_DIR=files

# Ingestion
BATCH_SIZE=64
RECREATE_COLLECTION=false
